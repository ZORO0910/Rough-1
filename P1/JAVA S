// ✅ ADD COMPLAINT (OFFLINE STORAGE)
window.addComplaint = function () {
    let regNo = document.getElementById("regNo").value;
    let name = document.getElementById("name").value;
    let room = document.getElementById("room").value;
    let issue = document.getElementById("issue").value;

    // Basic validation
    if (!regNo || !name || !room || !issue) {
        alert("Please fill all fields!");
        return;
    }

    try {
        // Fetch existing complaints or start empty list
        let complaints = JSON.parse(localStorage.getItem('complaints')) || [];
        
        // Add new complaint
        complaints.push({
            id: Date.now().toString(),
            regNo: regNo,
            name: name,
            room: room,
            issue: issue,
            status: "Pending",
            photo: ""
        });
        
        // Save back to local storage
        localStorage.setItem('complaints', JSON.stringify(complaints));

        alert("✅ Complaint Added Successfully!");

        // Clear inputs
        document.getElementById("regNo").value = "";
        document.getElementById("name").value = "";
        document.getElementById("room").value = "";
        document.getElementById("issue").value = "";

        loadComplaints();

    } catch (error) {
        console.error("Error adding complaint:", error);
        alert("❌ Error: " + error.message);
    }
};

// ✅ RESOLVE WITH IMAGE (LOCAL BASE64 STORAGE)
window.resolve = function (id) {
    let input = document.createElement("input");
    input.type = "file";
    input.accept = "image/*";

    input.onchange = function () {
        let file = input.files[0];
        if (!file) return;

        let reader = new FileReader();
        
        // Read the image file and convert to an offline Base64 string
        reader.onload = function(e) {
            let url = e.target.result; 
            
            try {
                let complaints = JSON.parse(localStorage.getItem('complaints')) || [];
                let idx = complaints.findIndex(c => c.id === id);
                
                if (idx !== -1) {
                    complaints[idx].status = "Resolved";
                    complaints[idx].photo = url; // Save the base64 string
                    localStorage.setItem('complaints', JSON.stringify(complaints));
                    
                    alert("✅ Complaint Resolved!");
                    loadComplaints();
                }
            } catch (error) {
                console.error("Error resolving complaint:", error);
                
                // Browsers usually have a 5MB local storage limit 
                if (error.name === 'QuotaExceededError') {
                    alert("❌ Error: The image file is too large to save offline format (Limit ~5MB). Please resolve without a photo, or choose a smaller size image.");
                } else {
                    alert("❌ Error: " + error.message);
                }
            }
        };
        reader.readAsDataURL(file);
    };

    input.click();
};

// ✅ LOAD COMPLAINTS
function loadComplaints() {
    try {
        let complaints = JSON.parse(localStorage.getItem('complaints')) || [];
        let output = "";

        complaints.forEach((c) => {
            output += `
            <div class="card">
                <p><b>${c.regNo}</b> | ${c.name} | Room: ${c.room}</p>
                <p>${c.issue}</p>
                <p>Status: ${c.status}</p>

                ${c.status === "Pending"
                    ? `<button onclick="resolve('${c.id}')">Resolve</button>`
                    : `<p>Resolved ✅</p>
                       <img src="${c.photo}" width="100" style="margin-top: 10px; border-radius: 4px; border: 1px solid #ccc;"/>`
                }
            </div>
            `;
        });

        document.getElementById("list").innerHTML = output;

    } catch (error) {
        console.error("Error loading complaints:", error);
        alert("❌ Error loading data: " + error.message);
    }
}

// Load on start
loadComplaints();